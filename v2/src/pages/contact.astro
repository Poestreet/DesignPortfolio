---
import { ViewTransitions } from "astro:transitions";
import ContactIsland from "../components/islands/ContactIsland";
import "../styles/global.css";

const seo = {
  title:       "Contact — Julien Bourcet, Senior Product Designer",
  description: "Prendre contact avec Julien Bourcet, Senior Product Designer.",
  ogImage:     "/og/OGimage.png",
  url:         "https://julienbourcet.fr/contact",
  canonical:   "https://julienbourcet.fr/contact",
};
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />

    <meta property="og:title"       content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image"       content={seo.ogImage} />
    <meta property="og:url"         content={seo.url} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="fr_FR" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image"       content={seo.ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,700&family=Outfit:wght@400;500;600;800&display=swap"
    />

    <ViewTransitions />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>

    <!-- Contenu statique — SEO et lecteurs d'écran -->
    <main id="main-content" tabindex="-1" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;">
      <h1>Contact — Julien Bourcet</h1>
      <p>Prendre contact avec Julien Bourcet, Senior Product Designer.</p>
      <nav aria-label="Navigation principale">
        <a href="/">Accueil</a>
        <a href="/cases">Études de cas</a>
        <a href="/about">À propos</a>
      </nav>
    </main>

    <!-- Formulaire statique pour détection Netlify Forms au build -->
    <form name="contact" netlify netlify-honeypot="bot-field" hidden>
      <input type="text"  name="name" />
      <input type="email" name="email" />
      <textarea name="message"></textarea>
    </form>

    <div style="position:fixed;inset:0;" aria-hidden="true">
      <ContactIsland client:load />
    </div>
  </body>
</html>
