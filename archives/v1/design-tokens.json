  },

  "color": {
    "$description": "Palette complète — correspond aux Paint Styles Portfolio/*",

    "brand": {
      "primary-blue": {
        "$value": "#070071",
        "$type": "color",
        "$description": "Couleur principale. Fond des composants, textes sur blanc."
      },
      "almost-white": {
        "$value": "#fafafa",
        "$type": "color",
        "$description": "Blanc cassé. Textes, tirets, icônes sur fond bleu."
      }
    },

    "ui": {
      "text-placeholder": {
        "$value": "rgba(250, 250, 250, 0.70)",
        "$type": "color",
        "$description": "Texte placeholder dans les champs de formulaire."
      },
      "border-subtle": {
        "$value": "rgba(250, 250, 250, 0.60)",
        "$type": "color",
        "$description": "Bordure inférieure des champs de formulaire (état Default)."
      },
      "binary-deco": {
        "$value": "rgba(250, 250, 250, 0.55)",
        "$type": "color",
        "$description": "Élément décoratif binaire (masque homepage)."
      },
      "tag-background": {
        "$value": "rgba(250, 250, 250, 0.20)",
        "$type": "color",
        "$description": "Fond des pills / tags sur fond bleu."
      }
    },

    "feedback": {
      "error": {
        "$value": "#ff4d4d",
        "$type": "color",
        "$description": "Erreur — bordure et texte état Error dans FormField."
      }
    },

    "overlay": {
      "vignette-hero": {
        "$value": "rgba(0, 0, 0, 0.45)",
