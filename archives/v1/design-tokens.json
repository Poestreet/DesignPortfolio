        "$value": "999px",
        "$type": "dimension",
        "$description": "Border-radius pour les pills / tags."
      },
      "radius-sm": {
        "$value": "2px",
        "$type": "dimension",
        "$description": "Rayon léger pour les éléments de navigation."
      }
