---
import { ViewTransitions } from "astro:transitions";
import CasesIsland from "../components/islands/CasesIsland";
import StaticBackground from "../components/StaticBackground.astro";
import "../styles/global.css";

const seo = {
  title:       "Case Studies — Julien Bourcet, Senior Product Designer",
  description: "SNCF Connect cart redesign (live 2+ years) and Manutan search engine optimisation (+2.9% conversion). Senior Product Designer work.",
  ogImage:     "https://julienbourcet.fr/og/OGimage.png",
  url:         "https://julienbourcet.fr/cases",
  canonical:   "https://julienbourcet.fr/cases",
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />

    <meta property="og:title"       content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image"       content={seo.ogImage} />
    <meta property="og:url"         content={seo.url} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="en_US" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image"       content={seo.ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,700&family=Outfit:wght@400;500;600;800&display=swap"
    />

    <ViewTransitions />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Contenu statique — SEO et lecteurs d'écran -->
    <main id="main-content" tabindex="-1" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;color:#fafafa;">
      <h1>Cases — Julien Bourcet</h1>

      <article>
        <h2>SNCF Connect — B2C cart redesign</h2>
        <p>
          Structural redesign of the SNCF Connect shopping cart.
          Challenge: reorganise the information hierarchy to simplify the journey
          and integrate legal requirements (insurance, mandatory notices).
        </p>
        <h3>My role</h3>
        <ul>
          <li>UX/UI governance and redesign strategy</li>
          <li>Prioritisation and design of the new cart</li>
          <li>Design and validation of complex cases (multiple products)</li>
          <li>Collaboration with the legal team for compliance</li>
          <li>Validation through targeted user testing</li>
        </ul>
        <h3>Results</h3>
        <p>
          Delivered on time, unanimous sign-off from all stakeholders.
          The page is still live two years after launch.
        </p>
      </article>

      <article>
        <h2>Manutan — Search engine optimisation</h2>
        <p>
          Turning the Manutan search experience into a competitive advantage.
          Goal: reduce SEA bounce rate and increase conversion rate.
        </p>
        <h3>My role</h3>
        <ul>
          <li>Quantitative and qualitative data analysis</li>
          <li>Iterative design (forms, filters, results layout)</li>
          <li>Validation through A/B testing and user interviews</li>
        </ul>
        <h3>Measured results</h3>
        <ul>
          <li>+22% to +33% clicks on products</li>
          <li>+22% to +66% add-to-cart</li>
          <li>+92% to +123% clicks on categories</li>
          <li>+2.9% search-driven conversion rate</li>
          <li>+2.8% search revenue share</li>
        </ul>
      </article>

      <nav aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </main>

    <div style="position:fixed;inset:0;z-index:0;" aria-hidden="true">
      <StaticBackground />
    </div>
    <div style="position:fixed;inset:0;z-index:1;" aria-hidden="true">
      <CasesIsland client:only="react" />
    </div>
  </body>
</html>
