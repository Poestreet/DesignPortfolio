---
// Fond animé statique — rendu dans le HTML Astro AVANT hydration React.
// Présent pendant la View Transition CSS, élimine le fond vide au slide.
// Utilisé sur About, Cases, Contact (pas Homepage — design masqué spécifique).
const image = "/assets/05ecf1ce226d7b081d77b91c5a9eada68ab72e0a.webp";
---
<div class="sb-wrapper">
  <style>
    .sb-wrapper {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    @keyframes sb-driftX {
      0%   { transform: translateX(0px); }
      100% { transform: translateX(-140px); }
    }
    @keyframes sb-driftY {
      0%   { transform: translateY(0px); }
      100% { transform: translateY(-100px); }
    }
    @keyframes sb-driftScale {
      0%   { transform: scale(1); }
      100% { transform: scale(1.18); }
    }
    .sb-outer {
      position: absolute;
      top: -20%;
      left: -20%;
      width: 140%;
      height: 140%;
      animation: sb-driftX 3.3s ease-in-out infinite alternate;
      will-change: transform;
    }
    @media (max-width: 768px) {
      .sb-outer { width: 200%; height: 200%; }
    }
    .sb-inner {
      width: 100%;
      height: 100%;
      animation: sb-driftY 2.1s ease-in-out infinite alternate;
      will-change: transform;
    }
    .sb-scale {
      width: 100%;
      height: 100%;
      animation: sb-driftScale 4.5s ease-in-out infinite alternate;
      will-change: transform;
    }
    .sb-img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
    }
    @media (prefers-reduced-motion: reduce) {
      .sb-outer, .sb-inner, .sb-scale { animation: none; }
    }
  </style>
  <div class="sb-outer">
    <div class="sb-inner">
      <div class="sb-scale">
        <img src={image} class="sb-img" alt="" draggable="false" />
      </div>
    </div>
  </div>
</div>
